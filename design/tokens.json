{
  "$schema": "internal:busy-office-tokens/v1",
  "meta": {
    "project": "busy-office",
    "version": "0.1.0",
    "note": "Single source for all visual values. Screen specs and code reference token names, never literals. Palette below is a placeholder pending logo/identity work (Claude Design brief)."
  },
  "color": {
    "bg":            { "value": "#0F1115", "role": "app background (dark-first)" },
    "surface":       { "value": "#181B22", "role": "cards, panels, inspector" },
    "surface-raised":{ "value": "#20242E", "role": "hover, modals" },
    "text":          { "value": "#E8EAF0", "role": "primary text" },
    "text-muted":    { "value": "#9AA1B0", "role": "secondary text, timestamps" },
    "accent":        { "value": "#4C8DFF", "role": "links, active nav, focus ring" },
    "approve":       { "value": "#2FBF71", "role": "gate approve, healthy status" },
    "reject":        { "value": "#E5484D", "role": "gate reject, error status" },
    "pending":       { "value": "#F5A524", "role": "awaiting-human states" },
    "border":        { "value": "#2A2F3A", "role": "dividers, card edges" }
  },
  "font": {
    "ui":   { "value": "Inter, system-ui, sans-serif", "role": "all UI text" },
    "mono": { "value": "JetBrains Mono, ui-monospace, monospace", "role": "event payloads, IDs, code" }
  },
  "size": {
    "text-xs": { "value": "12px" }, "text-sm": { "value": "13px" },
    "text-md": { "value": "15px" }, "text-lg": { "value": "18px" },
    "text-xl": { "value": "24px" }
  },
  "space": {
    "1": { "value": "4px" }, "2": { "value": "8px" }, "3": { "value": "12px" },
    "4": { "value": "16px" }, "6": { "value": "24px" }, "8": { "value": "32px" }
  },
  "radius": {
    "sm": { "value": "6px" }, "md": { "value": "10px" }, "full": { "value": "999px" }
  },
  "motion": {
    "fast": { "value": "120ms ease-out" }, "normal": { "value": "200ms ease-out" }
  },
  "assets": {
    "repo": "TBD: public assets repo (MOD-ASSETS)",
    "pin":  "TBD: tag or commit SHA — never HEAD (PRN-08)"
  }
}
